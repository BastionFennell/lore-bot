---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { lookupSlug } from '../lib/lore-index.mjs';
import { inlineLinks } from '../lib/inline-links.mjs';

const terms = (await getCollection('glossary')).sort((a, b) =>
  a.data.term.localeCompare(b.data.term)
);
---

<Base title="Glossary" summary="Terms of art from the Sundered Isles.">
  <h1>Glossary</h1>
  {terms.length > 0 ? (
    <dl class="glossary">
      {terms.map((t) => {
        const target = t.data.link_slug ? lookupSlug(t.data.link_slug) : null;
        return (
          <>
            <dt id={t.id}>{t.data.term}</dt>
            <dd>
              <Fragment set:html={inlineLinks(t.data.definition)} />
              {target && (
                <>
                  {' '}<a href={target.url}>See {target.title} &rarr;</a>
                </>
              )}
            </dd>
          </>
        );
      })}
    </dl>
  ) : (
    <p class="empty-state">No terms yet &mdash; the chronicle awaits.</p>
  )}
</Base>
