# --- LoreBot configuration (copy to bot/.env and fill in) ---

# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token).
DISCORD_TOKEN=

# Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Model override (default: claude-opus-4-8).
ANTHROPIC_MODEL=claude-opus-4-8

# Reasoning effort: low | medium | high (default: low). "low" keeps replies
# fast; raise it if the bot misreads intent on tricky requests.
ANTHROPIC_EFFORT=low

# The one server and one channel the bot listens in (right-click -> Copy ID;
# enable Developer Mode in Discord settings first).
GUILD_ID=
CHANNEL_ID=

# Comma-separated Discord user IDs allowed to talk to the bot (the two players).
ALLOWED_USER_IDS=

# Path to the git repo root (defaults to this repo's root — the parent of bot/).
REPO_PATH=

# Optional: base URL of the deployed site, used when linking committed pages.
SITE_BASE_URL=
